# Application settings
APP_NAME=celan_arch_prototype
APP_DEBUG=true
APP_PORT=8000
APP_DOMAIN=http://localhost:8000
APP_DATA_DIR=./data

# Superuser settings
APP_SUPERUSER_EMAIL=admin@example.com
APP_SUPERUSER_PASSWORD=admin123

# Database settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=password

# Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Broker settings (NATS or Kafka)
BROKER_TYPE=nats
BROKER_NATS_URL=nats://localhost:4222
BROKER_NATS_STREAM=app_events
BROKER_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
BROKER_KAFKA_TOPIC_PREFIX=app

# Auth settings
AUTH_JWT_SECRET=super-secret-key-for-jwt-signing-change-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_EXPIRE_SECONDS=900
AUTH_JWT_REFRESH_EXPIRE_SECONDS=604800
AUTH_ALLOW_SIMPLE_PASSWORDS=false

# Taskiq settings
TASKS_BROKER_URL=nats://localhost:4222
TASKS_RESULT_BACKEND=redis://localhost:6379/0
